stage('Push Image to ECR') {
    steps {
        withAWS(credentials: 'aws-token', region: 'us-east-1') {
            script {
                def accountId = "176545285953"
                def region = "us-east-1"
                def repoName = "nodejs"
                def imageTag = "${BUILD_NUMBER}"
                def ecrUrl = "${accountId}.dkr.ecr.${region}.amazonaws.com"

                sh """
                # Login to ECR
                aws ecr get-login-password --region ${region} | docker login --username AWS --password-stdin ${ecrUrl}

                # Tag Docker image
                docker tag priyankayadav911/${repoName}:${imageTag} ${ecrUrl}/${repoName}:${imageTag}

                # Push to ECR
                docker push ${ecrUrl}/${repoName}:${imageTag}
                """
            }
        }
    }
}
